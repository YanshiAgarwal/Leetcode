# Reverse Linked List
class Solution {
    public ListNode reverseList(ListNode head) {
        Stack<Integer> stack=new Stack<>();
        ListNode fast=head;
        ListNode slow=null;
        ListNode temp=null;
        while(fast!=null){
            temp=slow; 
            slow=fast;
            fast=fast.next;
            slow.next=temp;
            
            
        }
        return slow;
    }
}
